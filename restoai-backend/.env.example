# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Webhook mode (production). Leave blank to use long-polling (development).
TELEGRAM_WEBHOOK_URL=https://your-domain.example.com
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
# URL path segment for the webhook endpoint (keep this a random token).
TELEGRAM_WEBHOOK_SECRET_PATH=your-secret-url-path-segment

# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://restoai:restoai@localhost:5432/restoai

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Dispatcher API ───────────────────────────────────────────────────────────
# Shared bearer token used by the dispatcher dashboard to call the REST API.
DISPATCHER_API_TOKEN=your-dispatcher-api-token-here

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
